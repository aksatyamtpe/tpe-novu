{
  "name": "tpe-novu-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "TPE Communication System — Novu Framework workflows for the 49 lifecycle triggers",
  "scripts": {
    "dev": "next dev -p 4001",
    "build": "next build",
    "start": "next start -p 4001",
    "sync": "novu sync --bridge-url http://bridge:4001/api/novu --api-url http://localhost:3000 --secret-key $NOVU_SECRET_KEY"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.620.0",
    "@novu/framework": "^2.6.0",
    "mongodb": "^6.8.0",
    "next": "14.2.10",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "novu": "^2.0.0",
    "typescript": "5.5.3"
  }
}
