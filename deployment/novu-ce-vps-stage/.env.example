# =============================================================================
# Novu CE Stack — Environment Configuration
# -----------------------------------------------------------------------------
# Copy to .env and fill in. NEVER commit the real .env to source control.
# Generate secrets with:    ./scripts/bootstrap.sh
# =============================================================================

# -- Image version pin ---------------------------------------------------------
# Pin to an exact tag from https://github.com/novuhq/novu/releases.
# Do NOT use :latest. Re-validate before bumping; migrations may be needed.
NOVU_VERSION=2.3.0

# -- Public hostnames (VPS STAGE: IP-only HTTP) --------------------------------
# Caddy fronts everything on :80; URLs are bare-IP, no ports.
# When DNS is later set up for vps.amarjitm2.com, change all references to
# https://vps.amarjitm2.com (and update caddy/Caddyfile to use a hostname
# block so Caddy obtains a Let's Encrypt cert automatically).
HOST_NAME=http://103.138.96.180
API_ROOT_URL=http://103.138.96.180/api
FRONT_BASE_URL=http://103.138.96.180
WS_PUBLIC_URL=ws://103.138.96.180/ws
BRIDGE_PUBLIC_URL=http://103.138.96.180/bridge

# Used only when fronting with a path-based reverse proxy (company.com/novu)
WS_CONTEXT_PATH=

# -- Runtime mode --------------------------------------------------------------
NODE_ENV=production
API_PORT=3000

# -- Sign-up lockdown ----------------------------------------------------------
# Set to "true" AFTER provisioning the first admin account.
# Forgetting this is the #1 self-host security mistake observed in the wild.
DISABLE_USER_REGISTRATION=false

# =============================================================================
# SECRETS — generated by bootstrap.sh; never reuse across environments
# =============================================================================
# 64-character random hex
JWT_SECRET=REPLACE_ME

# EXACTLY 32 characters. Used to encrypt provider credentials in MongoDB.
STORE_ENCRYPTION_KEY=REPLACE_ME_32_CHARS_EXACT_OK_OK

# 64-character random hex. Used by Bridge for HMAC verification.
NOVU_SECRET_KEY=REPLACE_ME

# =============================================================================
# MONGODB
# =============================================================================
MONGO_INITDB_ROOT_USERNAME=novu_root
MONGO_INITDB_ROOT_PASSWORD=REPLACE_ME_STRONG_PASSWORD
MONGO_URL=mongodb://novu_root:REPLACE_ME_STRONG_PASSWORD@mongodb:27017/novu-db?authSource=admin
MONGO_MIN_POOL_SIZE=10
MONGO_MAX_POOL_SIZE=50

# =============================================================================
# REDIS — two instances (queue + cache) per Novu best practice
# =============================================================================
# Queue Redis (BullMQ, AOF persistence on)
REDIS_HOST=redis-queue
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_ME_STRONG_PASSWORD

# Cache Redis (LRU, no persistence)
REDIS_CACHE_SERVICE_HOST=redis-cache
REDIS_CACHE_SERVICE_PORT=6379
REDIS_CACHE_PASSWORD=REPLACE_ME_STRONG_PASSWORD

# =============================================================================
# OBJECT STORAGE
# =============================================================================
# DEV: LocalStack S3 emulator (in-stack)
S3_LOCAL_STACK=http://localstack:4566
S3_BUCKET_NAME=novu-local
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# PROD: switch to real S3 — leave S3_LOCAL_STACK empty and set real values
# S3_LOCAL_STACK=
# S3_BUCKET_NAME=novu-prd-attachments
# S3_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=...     (or use IAM role on the host)
# AWS_SECRET_ACCESS_KEY=...

# =============================================================================
# OBSERVABILITY (optional)
# =============================================================================
# Sentry DSN — uncomment if using Sentry
# SENTRY_DSN=https://...@sentry.io/...

# =============================================================================
# REVERSE PROXY (Caddy) — set the hostname in caddy/Caddyfile, not here
# =============================================================================
