# =============================================================================
# SECRETS — must never enter the repo
# =============================================================================
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
id_ecdsa

# Real env files (templates with .example suffix are fine to commit)
.env
.env.local
.env.production
.env.development
.env.staging
.env.*.local
!.env.example
!.env.*.example

# Common credential filenames
secrets.json
credentials.json
service-account.json
gcp-key.json
aws-credentials
.aws/credentials

# =============================================================================
# Node / Next.js / TypeScript
# =============================================================================
node_modules/
.next/
out/
dist/
build/
.turbo/
.vercel/
coverage/
*.tsbuildinfo
.npm/
.yarn/cache/
.pnpm-store/

# =============================================================================
# Python (any helper scripts in docs/)
# =============================================================================
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
.mypy_cache/

# =============================================================================
# OS noise
# =============================================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# =============================================================================
# IDEs
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~

# =============================================================================
# Logs / runtime
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =============================================================================
# Local-only Claude state (the global memory lives outside the repo;
# only project-specific .claude config should be checked in)
# =============================================================================
.claude/sessions/
.claude/cache/

# macOS folder-icon metadata (0-byte files)
Icon

# Match macOS Icon files with trailing CR — Icon? catches any single char after "Icon"
Icon?
